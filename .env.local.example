# =============================================================================
# Kumbu Site — variáveis de ambiente (http://localhost:3000)
# Produção (Vercel): ver Kumbu_bakend/DEPLOY_BETA_CLOUDFLARE.md
# =============================================================================

NEXT_PUBLIC_KUMBU_API_URL=http://localhost:8080/api/v1

# Vercel (Production) — Settings → Environment Variables:
# NEXT_PUBLIC_KUMBU_API_URL=https://api.kumbu-market.com/api/v1
# NEXT_PUBLIC_SENTRY_DSN=...
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production

# NEXT_PUBLIC_SITE_URL=https://www.kumbu-market.com

# --- Monitorização (Sentry) — opcional em dev ---
# Crie 3 projectos em https://sentry.io (site, admin, api) e cole os DSNs.
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# Source maps em CI/produção (opcional):
# SENTRY_ORG=
# SENTRY_PROJECT=kumbu-site
# SENTRY_AUTH_TOKEN=

# OAuth (Google/Facebook): Client IDs públicos via GET /api/v1/auth/oauth/config
# Facebook code exchange corre no servidor Next.js (Vercel) — secrets só aqui:
# KUMBU_FACEBOOK_APP_ID=2091230542268519
# KUMBU_FACEBOOK_APP_SECRET=<secret da app Meta>
#
# Google — Erro 400 origin_mismatch:
# Em https://console.cloud.google.com → APIs e serviços → Credenciais → OAuth 2.0
# adiciona em «Origens JavaScript autorizadas»:
#   http://localhost:3000
#   https://www.kumbu-market.com
# Facebook — URL bloqueado:
# Em https://developers.facebook.com → App Kumbú → Facebook Login → Settings
# adiciona em «Valid OAuth Redirect URIs»:
#   https://www.kumbu-market.com/auth/callback
#   http://localhost:3000/auth/callback
# Guia completo: Kumbu_bakend/docs/OAUTH_PRODUCTION.md

# --- Dev no telemóvel (mesma Wi‑Fi) ---
# npm run dev:lan  →  http://192.168.x.x:3000 no telemóvel
# DEV_ALLOWED_ORIGINS=192.168.0.173
